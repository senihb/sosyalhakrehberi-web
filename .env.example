# The backend API origin.
#
# In production (Railway), set this to the real backend URL, e.g.:
#   NEXT_PUBLIC_API_BASE_URL=https://api.sosyalhakrehberi.com
#
# Any https:// URL is automatically routed through the Next.js proxy rewrite
# at /api-proxy (configured in next.config.ts), so browser requests never hit
# the backend directly. This avoids CORS issues and 502 errors.
#
# In local development, point this at your local backend server, e.g.:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# HTTP origins are used directly without proxying.
NEXT_PUBLIC_API_BASE_URL=https://api.sosyalhakrehberi.com

NEXT_PUBLIC_SITE_URL=https://sosyalhakrehberi.com
