{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        { "src": "package.json", "dest": "package.json" },
        { "src": "package-lock.json", "dest": "package-lock.json" },
        { "cmd": "npm install --include=dev" }
      ]
    }
  },
  "deploy": {
    "startCommand": "HOSTNAME=0.0.0.0 node .next/standalone/server.js"
  }
}
